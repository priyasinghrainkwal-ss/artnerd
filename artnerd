# ─────────────────────────────────────────────
# STEP 1: GENERATE IMAGE WITH DALL-E
# ─────────────────────────────────────────────
def generate_image(theme: dict, index: int) -> str:
    """Generate an AI image using DALL-E 3 and save locally."""
    print(f"  🎨 Generating image {index+1}/10: {theme['name']}")

    response = client.images.generate(
        model="dall-e-3",
        prompt=theme["prompt"],
        size="1024x1024",
        quality="hd",
        n=1,
    )

    image_url = response.data[0].url
    timestamp  = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename   = f"{SAVE_DIR}/post_{index+1}_{timestamp}.png"

    # Download image
    img_data = requests.get(image_url).content
    with open(filename, "wb") as f:
        f.write(img_data)

    print(f"     ✅ Saved: {filename}")
    return filename

# ─────────────────────────────────────────────
# STEP 2: GENERATE CAPTION
# ─────────────────────────────────────────────
def generate_caption(theme: dict, hashtag_set: str) -> str:
    """Generate an engaging caption using GPT."""
    print(f"  ✍️  Generating caption for: {theme['name']}")

    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {
                "role": "system",
                "content": (
                    "You are a creative Instagram content writer for an AI digital art workspace account. "
                    "Write short, engaging, punchy captions (max 3 lines). "
                    "Use 1-2 relevant emojis. No hashtags (added separately). Keep it inspiring and aesthetic."
                )
            },
            {
                "role": "user",
                "content": f"Write an Instagram caption for this AI art workspace theme: '{theme['name']}'. Hook: {theme['caption_hook']}"
            }
        ],
        max_tokens=120,
    )

    caption_text = response.choices[0].message.content.strip()
    full_caption  = f"{caption_text}\n\n🎨 Created with AI ✨\n\n{hashtag_set}"
    return full_caption

# ─────────────────────────────────────────────
# STEP 3: UPLOAD IMAGE TO INSTAGRAM
# ─────────────────────────────────────────────
def upload_to_instagram(image_path: str, caption: str) -> bool:
    """
    Post image to Instagram via Meta Graph API.
    
    NOTE: Instagram Graph API requires a PUBLIC image URL.
    Options to host images publicly:
      - Imgur API (free)
      - AWS S3 public bucket
      - Cloudinary (free tier)
      - Your own server
    
    Set IMAGE_HOST_URL in .env OR use the imgur_upload() helper below.
    """
    # Upload image to Imgur first to get a public URL
    public_url = imgur_upload(image_path)
    if not public_url:
        print("     ❌ Failed to get public image URL. Skipping post.")
        return False

    # Step A: Create media container
    create_url = f"https://graph.facebook.com/v19.0/{INSTAGRAM_ACCOUNT_ID}/media"
    create_payload = {
        "image_url": public_url,
        "caption":   caption,
        "access_token": ACCESS_TOKEN,
    }

    r = requests.post(create_url, data=create_payload)
    result = r.json()

    if "id" not in result:
        print(f"     ❌ Container creation failed: {result}")
        return False

    container_id = result["id"]
    print(f"     📦 Container created: {container_id}")

    # Wait for processing
    time.sleep(5)

    # Step B: Publish the container
    publish_url = f"https://graph.facebook.com/v19.0/{INSTAGRAM_ACCOUNT_ID}/media_publish"
    publish_payload = {
        "creation_id":  container_id,
        "access_token": ACCESS_TOKEN,
    }

    r2 = requests.post(publish_url, data=publish_payload)
    result2 = r2.json()

    if "id" in result2:
        print(f"     ✅ Posted! Media ID: {result2['id']}")
        return result2["id"]
    else:
        print(f"     ❌ Publish failed: {result2}")
        return False

# ─────────────────────────────────────────────
# IMGUR UPLOAD (free public image hosting)
# ─────────────────────────────────────────────
def imgur_upload(image_path: str) -> str:
    """Upload image to Imgur and return public URL."""
    imgur_client_id = os.getenv("IMGUR_CLIENT_ID")
    if not imgur_client_id:
        print("     ⚠️  IMGUR_CLIENT_ID not set. Set it in .env for image hosting.")
        return None

    headers = {"Authorization": f"Client-ID {imgur_client_id}"}
    with open(image_path, "rb") as f:
        response = requests.post(
            "https://api.imgur.com/3/image",
            headers=headers,
            files={"image": f}
        )

    data = response.json()
    if data.get("success"):
        url = data["data"]["link"]
        print(f"     🌐 Imgur URL: {url}")
        return url
    else:
        print(f"     ❌ Imgur upload failed: {data}")
        return None

# ─────────────────────────────────────────────
# STEP 4: LOG POST
# ─────────────────────────────────────────────
def log_post(theme_name: str, image_path: str, caption: str, media_id):
    log = []
    if os.path.exists(LOG_FILE):
        with open(LOG_FILE, "r") as f:
            log = json.load(f)

    log.append({
        "timestamp":  datetime.now().isoformat(),
        "theme":      theme_name,
        "image_path": image_path,
        "caption":    caption[:100] + "...",
        "media_id":   str(media_id) if media_id else "failed",
        "status":     "posted" if media_id else "failed"
    })

    with open(LOG_FILE, "w") as f:
        json.dump(log, f, indent=2)

# ─────────────────────────────────────────────
# MAIN DAILY JOB
# ─────────────────────────────────────────────
def run_daily_posts():
    """Main function: generates and posts 10 images throughout the day."""
    print(f"\n{'='*55}")
    print(f"🚀 Starting Daily Instagram Run — {datetime.now().strftime('%Y-%m-%d %H:%M')}")
    print(f"{'='*55}")

    # Pick hashtag set for today (rotate daily)
    day_of_year   = datetime.now().timetuple().tm_yday
    hashtag_set   = HASHTAG_SETS[day_of_year % len(HASHTAG_SETS)]

    # Shuffle themes so posts vary each day
    themes_today  = THEMES.copy()
    random.shuffle(themes_today)

    # Posting times spread across the day (10 posts)
    post_times = [
        "08:00", "09:30", "11:00", "13:00", "15:00",
        "17:00", "18:30", "20:00", "21:30", "23:00"
    ]

    print(f"\n📅 Scheduled post times: {', '.join(post_times)}\n")

    for i, theme in enumerate(themes_today):
        print(f"\n─── Post {i+1}/10 ─── [{post_times[i]}] ───────────────")

        try:
            # 1. Generate image
            image_path = generate_image(theme, i)

            # 2. Generate caption
            caption = generate_caption(theme, hashtag_set)

            # 3. Post to Instagram
            media_id = upload_to_instagram(image_path, caption)

            # 4. Log result
            log_post(theme["name"], image_path, caption, media_id)

            # Wait before next post (avoid rate limits)
            if i < 9:
                wait_seconds = 90 * 60  # 90 minutes between posts
                print(f"\n⏳ Waiting {wait_seconds//60} minutes before next post...\n")
                time.sleep(wait_seconds)

        except Exception as e:
            print(f"     ❌ Error on post {i+1}: {e}")
            log_post(theme["name"], "", "", None)
            continue

    print(f"\n{'='*55}")
    print("✅ All 10 posts completed for today!")
    print(f"{'='*55}\n")

